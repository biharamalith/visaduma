{
  "name": "visaduma-backend",
  "version": "1.0.0",
  "description": "VisaDuma Super App Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:db": "node test-db-connection.js",
    "test:redis": "node test-redis-connection.js",
    "test:s3": "node test-s3-connection.js",
    "test:socket": "node test-socket-connection.js",
    "test:migrations": "node test-migrations.js",
    "s3:setup": "node src/utils/s3Setup.js setup",
    "s3:info": "node src/utils/s3Setup.js info",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "migrate:status": "node src/utils/migrationStatus.js"
  },
  "keywords": [
    "visaduma",
    "super-app",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "aws-sdk": "^2.1543.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.11.3",
    "socket.io": "^4.6.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "socket.io-client": "^4.8.3"
  }
}
